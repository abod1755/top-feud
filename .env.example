# ---------------------------------------------------------------------------
# Top Feud environment configuration
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Project Settings → API). Never commit `.env.local`.
# ---------------------------------------------------------------------------

# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public — the canonical site origin (used for metadata, OG tags, sitemap).
# Use http://localhost:3000 locally and your real domain in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only — NEVER expose. Used by privileged server actions / edge functions.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only — bootstrap admin account email (granted admin on first login).
ADMIN_EMAIL=

# Server-only — Moyasar secret key (sk_test_... / sk_live_...). Powers ticket
# checkout. Get it from dashboard.moyasar.com → Settings → API Keys.
# Also set the same value as a Supabase secret for the moyasar-webhook function:
#   supabase secrets set MOYASAR_SECRET_KEY=sk_live_xxx
MOYASAR_SECRET_KEY=
